{
    admin off
}

# --- INGRESS: Access to Agent ---
:8443 {
    request_body {
        max_size 256KB
    }

    tls /etc/caddy/certs/caddy.crt /etc/caddy/certs/caddy.key

    reverse_proxy https://claude-server:8000 {
        transport http {
            tls_trusted_ca_certs /etc/caddy/certs/ca.crt
        }
    }
}


# --- EGRESS: Anthropic API only ---
# LiteLLM proxy routes outbound Anthropic calls through this endpoint.
# Only api.anthropic.com is permitted — all other upstream targets are blocked.
:8081 {
    tls /etc/caddy/certs/caddy.crt /etc/caddy/certs/caddy.key

    reverse_proxy https://api.anthropic.com:443 {
        # Preserve the original Host header so Anthropic sees the correct SNI/Host
        header_up Host api.anthropic.com
        transport http {
            tls_server_name api.anthropic.com
        }
    }
}
