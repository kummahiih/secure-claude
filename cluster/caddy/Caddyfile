{
    admin off
}

# --- INGRESS: Access to Agent and Log Server ---
:8443 {
    request_body {
        max_size 256KB
    }

    tls /etc/caddy/certs/caddy.crt /etc/caddy/certs/caddy.key

    handle_path /logs/* {
        reverse_proxy https://log-server:8443 {
            transport http {
                tls_trusted_ca_certs /etc/caddy/certs/ca.crt
            }
        }
    }

    handle {
        reverse_proxy https://claude-server:8000 {
            transport http {
                tls_trusted_ca_certs /etc/caddy/certs/ca.crt
            }
        }
    }
}


# --- INGRESS: Access to Codex Agent ---
:8444 {
    request_body {
        max_size 256KB
    }

    tls /etc/caddy/certs/caddy.crt /etc/caddy/certs/caddy.key

    handle {
        reverse_proxy https://codex-server:8000 {
            transport http {
                tls_trusted_ca_certs /etc/caddy/certs/ca.crt
            }
        }
    }
}


# --- EGRESS: Anthropic API only ---
# LiteLLM proxy routes outbound Anthropic calls through this endpoint.
# Only api.anthropic.com is permitted — all other upstream targets are blocked.
:8081 {
    tls /etc/caddy/certs/caddy.crt /etc/caddy/certs/caddy.key

    reverse_proxy https://api.anthropic.com:443 {
        # Preserve the original Host header so Anthropic sees the correct SNI/Host
        header_up Host api.anthropic.com
        transport http {
            tls_server_name api.anthropic.com
        }
    }
}

# --- EGRESS: OpenAI API only ---
# LiteLLM proxy routes outbound OpenAI/Codex calls through this endpoint.
# Only api.openai.com is permitted — all other upstream targets are blocked.
:8082 {
    tls /etc/caddy/certs/caddy.crt /etc/caddy/certs/caddy.key

    reverse_proxy https://api.openai.com:443 {
        # Preserve the original Host header so OpenAI sees the correct SNI/Host
        header_up Host api.openai.com
        transport http {
            tls_server_name api.openai.com
        }
    }
}
